{
  "permissions": {
    "allow": [
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(swift package:*)",
      "Bash(quality-gate:*)",
      "Bash(quality-gate)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
